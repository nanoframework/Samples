<Project Sdk="nanoFramework.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netnano1.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <RootNamespace>SimpleWpf</RootNamespace>
    <AssemblyName>SimpleWpf</AssemblyName>
    <DefineConstants>$(DefineConstants);ESP32;</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="nanoFramework.CoreLibrary" Version="1.17.11" />
    <PackageReference Include="nanoFramework.Graphics" Version="1.2.45" />
    <PackageReference Include="nanoFramework.Hardware.Esp32" Version="1.6.37" />
    <PackageReference Include="nanoFramework.ResourceManager" Version="1.2.32" />
    <PackageReference Include="nanoFramework.Runtime.Events" Version="1.11.32" />
    <PackageReference Include="nanoFramework.Runtime.Native" Version="1.7.11" />
    <PackageReference Include="nanoFramework.System.Collections" Version="1.5.67" />
    <PackageReference Include="nanoFramework.System.Device.Gpio" Version="1.1.57" />
    <PackageReference Include="nanoFramework.System.Math" Version="1.5.116" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\SimpleWpf\GpioButtonInputProvider.cs">
      <Link>GpioButtonInputProvider.cs</Link>
    </Compile>
    <Compile Include="..\SimpleWpf\Program.cs">
      <Link>Program.cs</Link>
    </Compile>
    <Compile Include="..\SimpleWpf\SimpleWPFApplication.cs">
      <Link>SimpleWPFApplication.cs</Link>
    </Compile>
    <Compile Include="..\SimpleWpf\Resource.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>Resource.resx</DependentUpon>
    </Compile>
    <EmbeddedResource Include="..\SimpleWpf\Resource.resx" Link="Resource.resx" />
  </ItemGroup>

</Project>
