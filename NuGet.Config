<?xml version="1.0" encoding="utf-8"?>
<!--
  Dev-local feed for the SDK-style migration (move-to-sdk).
  'local-sdk' points at the sibling nanoFramework.Sdk build output so samples can build
  against the unpublished nanoFramework.NET.Sdk. Remove 'local-sdk' once the SDK ships to
  nuget.org and pin the published version in global.json.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="local-sdk" value="../nanoFramework.Sdk/artifacts" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
