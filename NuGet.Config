<?xml version="1.0" encoding="utf-8"?>
<!-- Dev-local feed for the SDK-style migration; remove 'local-sdk' once the SDK ships to nuget.org. -->
<configuration>
  <packageSources>
    <clear />
    <add key="local-sdk" value="../nanoFramework.Sdk/artifacts" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
